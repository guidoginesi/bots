# ── Asana ────────────────────────────────────────────────────────────────────
# Personal Access Token del usuario "service"
ASANA_PAT=

# GIDs de los proyectos a escuchar (separados por coma)
ASANA_PROJECT_GIDS=

# URL pública del endpoint en Vercel
ASANA_WEBHOOK_TARGET_URL=https://your-app.vercel.app/api/asana/webhook

# ── Google Chat ───────────────────────────────────────────────────────────────
# Incoming Webhook URL del space del Directorio
GC_WEBHOOK_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production

# Tags que disparan el reenvío a Chat (separados por coma)
FORWARD_TAGS=#dir,@PowBoardBot
