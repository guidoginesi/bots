# ── Asana ────────────────────────────────────────────────────────────────────
# Personal Access Token del usuario "service"
ASANA_PAT=

# GIDs de los proyectos a escuchar (separados por coma)
ASANA_PROJECT_GIDS=

# URL pública del endpoint en Vercel
ASANA_WEBHOOK_TARGET_URL=https://your-app.vercel.app/api/asana/webhook

# ── Google Chat ───────────────────────────────────────────────────────────────
# Incoming Webhook URL del space del Directorio
GC_WEBHOOK_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production

# Tags que disparan el reenvío a Chat (separados por coma)
FORWARD_TAGS=#dir,@PowBoardBot

# ── HubSpot CRM (/reports/crm-dashboard.html) ───────────────────────────────
# Private App → Access token (pat-na1-...)
HUBSPOT_TOKEN=

# ── Informes HTML internos (/reports) ───────────────────────────────────────
# Contraseña compartida para dashboards en public/reports (cookie httpOnly)
REPORTS_PASSWORD=
# Opcional: secreto extra para firmar la cookie (si no se define, usa REPORTS_PASSWORD)
REPORTS_AUTH_SECRET=
